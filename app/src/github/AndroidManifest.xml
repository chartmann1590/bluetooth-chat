<?xml version="1.0" encoding="utf-8"?>
<!-- Github-flavor-only manifest overlay, merged into the main manifest by AGP. Adds the deep link
     Stripe Checkout redirects to on completion (see cloudflare-worker/src/index.js's successUrl) —
     the play flavor never needs this since Play Billing completes in-process. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <!-- exported=true is required: this intent-filter must be reachable from the browser that
             completes the Stripe Checkout redirect. Repeated here (not just inherited from the main
             manifest's MainActivity declaration via merge) so it's unambiguous in isolation too. -->
        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="meshtalk" android:host="billing" />
            </intent-filter>
        </activity>
    </application>
</manifest>
